  "keyFeatures": [
    "Automated PDF remediation to WCAG 2.1 Level AA standards",
    "AI-powered alt-text generation using AWS Bedrock",
    "Adobe PDF Services integration for professional tagging",
    "Dual processing modes: PDF-to-PDF and PDF-to-HTML",
    "Scalable serverless architecture with Lambda and ECS Fargate",
    "Step Functions workflow orchestration for complex document processing",
    "Pre and post-remediation accessibility auditing",
    "CloudWatch monitoring dashboards for processing transparency"
  ],
  "publicApiSurface": [
    "PdfSplitterLambda - S3-triggered PDF chunking",
    "PdfMergerLambda - Reassembles processed chunks",
    "TitleGeneratorLambda - AI-generated accessible titles",
    "PreRemediationAccessibilityChecker - Audits original PDFs",
    "PostRemediationAccessibilityChecker - Validates remediated output",
    "AdobeAutotagContainer - Adobe PDF Services tagging",
    "AltTextGeneratorContainer - Bedrock-powered image descriptions",
    "PdfAccessibilityRemediationWorkflow - Step Functions orchestration",
    "Pdf2HtmlPipeline - Lambda-based HTML conversion"
